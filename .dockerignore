# Dependencies
node_modules
npm-debug.log*
.pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (rebuilt in container)
.next
out
dist
build

# Git and IDE
# NOTE: .git must stay in the build context — fumadocs-mdx's last-modified
# plugin (versionControl: "git") reads git history during `next build`.
.gitignore
.cursor
.vscode
*.md
!content/**/*.md
!content/**/*.mdx

# Env and secrets
.env
.env.*
!.env.example

# Misc
Dockerfile*
.dockerignore
*.log
.DS_Store
